#
# Squire local environment
#

# Required for answer generation
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# Google OAuth (required for web UI login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Session cookie signing / CSRF derivation
# Generate one with: openssl rand -base64 48
SESSION_SECRET=replace_with_random_32_plus_character_string

# Comma-separated email allowlist for web UI login
SQUIRE_ALLOWED_EMAILS=your-email@example.com

# Optional tracing / observability
LANGFUSE_BASEURL=https://us.cloud.langfuse.com
LANGFUSE_PROJECT_ID=cmn1deprv071ead07hellcosn
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Optional eval runner defaults. CLI flags override these values.
# SQUIRE_EVAL_PROVIDER=anthropic
# SQUIRE_EVAL_MODEL=claude-sonnet-4-6
# SQUIRE_EVAL_RUN_LABEL=local-eval
#
# Future provider runner knobs. Leave unset until the provider runner supports them.
# SQUIRE_EVAL_REASONING_EFFORT=
# SQUIRE_EVAL_MAX_OUTPUT_TOKENS=
# SQUIRE_EVAL_TIMEOUT_MS=
# SQUIRE_EVAL_TOOL_LOOP_LIMIT=

# Server environment — development enables dev-only routes and no-cache asset serving
NODE_ENV=development

# Optional server overrides
# PORT defaults to 3000 in the main checkout and a managed derived port in linked worktrees
# PORT=3000
#
# Public base URL used in OAuth metadata responses
# SQUIRE_BASE_URL=http://localhost:3000

# Optional Postgres overrides
# By default, local dev uses checkout-managed databases on the local docker-compose service.
# Main checkout uses `squire` / `squire_test`; linked worktrees derive names from the checkout path.
# DATABASE_URL=postgres://squire:squire@localhost:5432/squire
# TEST_DATABASE_URL=postgres://squire:squire@localhost:5432/squire_test

# Optional data-path override for Gloomhaven Secretariat source data
# GHS_DATA_DIR=/absolute/path/to/gloomhavensecretariat/data/fh

# Advanced local override for worktree port-claim bookkeeping
# SQUIRE_PORT_CLAIM_DIR=/absolute/path/to/port-claims

# Opt in to the /dev/login route (plain POST to mint a session without Google OAuth).
# Required since SQR-106 as a third positive gate alongside NODE_ENV and DATABASE_URL.
# scripts/preview-serve.sh sets this automatically for Claude Code preview.
# Set it here only if you also want it available when running `npm run serve` directly.
# SQUIRE_DEV_LOGIN=1
