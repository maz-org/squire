ANTHROPIC_API_KEY=your_key_here

# Postgres connection strings default to checkout-local managed databases on the
# local docker-compose service. Main checkout uses `squire` / `squire_test`;
# linked worktrees derive names from the checkout path. Only set these if
# you're pointing at a different host or intentionally overriding the defaults:
# DATABASE_URL=postgres://user:pass@host:5432/db
# TEST_DATABASE_URL=postgres://user:pass@host:5432/db_test
