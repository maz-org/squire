ANTHROPIC_API_KEY=your_key_here

# Postgres connection strings default to the local docker-compose service
# (postgres://squire:squire@localhost:5432/{squire,squire_test}). Only set
# these if you're pointing at a different host:
# DATABASE_URL=postgres://user:pass@host:5432/db
# TEST_DATABASE_URL=postgres://user:pass@host:5432/db_test
