{
  "name": "squire",
  "version": "0.1.2",
  "description": "Frosthaven AI assistant with RAG over rulebooks",
  "type": "module",
  "scripts": {
    "check": "npm run typecheck && npm run lint && npm run lint:css && npm run lint:md && npm run format:check && npm test",
    "index": "node src/index-docs.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/db-migrate.ts",
    "db:migrate:test": "NODE_ENV=test node scripts/db-migrate.ts",
    "db:reset": "node scripts/db-reset.ts",
    "db:reset:test": "NODE_ENV=test node scripts/db-reset.ts",
    "seed": "node scripts/seed-cards.ts",
    "seed:cards": "node scripts/seed-cards.ts",
    "seed:dev-user": "node scripts/seed-dev-user.ts",
    "seed:dev": "npm run seed:cards && npm run seed:dev-user",
    "query": "node src/query.ts",
    "serve": "node src/server.ts",
    "eval": "node eval/run.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "agent:check": "node scripts/check-agent-parity.ts",
    "agent:export-learnings": "node scripts/export-gstack-learnings.ts",
    "agent:install-launchagent": "node scripts/install-agent-learnings-launchagent.ts",
    "lint": "eslint src/ test/ scripts/",
    "lint:css": "stylelint 'src/web-ui/**/*.css'",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#data' '#.beads' '#.gstack'",
    "format": "prettier --write src/ test/",
    "format:check": "prettier --check src/ test/",
    "hooks:install": "node scripts/setup-git-hooks.ts",
    "prepare": "npm run hooks:install && npm run agent:install-launchagent"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.md": [
      "prettier --write",
      "markdownlint-cli2 --fix"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@hono/node-server": "^1.19.13",
    "@langfuse/client": "^5.0.2",
    "@langfuse/otel": "^5.0.2",
    "@langfuse/tracing": "^5.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/instrumentation-pg": "^0.66.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@tailwindcss/node": "^4.2.2",
    "@tailwindcss/oxide": "^4.2.2",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.4.0",
    "drizzle-orm": "1.0.0-beta.21",
    "google-auth-library": "^10.6.2",
    "hono": "^4.12.12",
    "htmx.org": "^2.0.7",
    "markdown-it": "^14.1.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "1.0.0-beta.22-41a7d21",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.2",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "brace-expansion": "5.0.5",
    "sharp": "0.34.5",
    "smol-toml": "1.6.1"
  }
}
