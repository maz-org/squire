{
  "name": "squire",
  "version": "0.1.0",
  "description": "Frosthaven AI assistant with RAG over rulebooks",
  "type": "module",
  "scripts": {
    "index": "node src/index-docs.ts",
    "query": "node src/query.ts",
    "serve": "node src/server.ts",
    "extract": "node src/extract-card-data.ts",
    "eval": "node eval/run.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#data' '#.beads'",
    "format": "prettier --write src/ test/",
    "format:check": "prettier --check src/ test/",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@hono/node-server": "^1.19.11",
    "@langfuse/client": "^5.0.2",
    "@langfuse/otel": "^5.0.1",
    "@langfuse/tracing": "^5.0.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.3.1",
    "hono": "^4.12.9",
    "pdf-parse": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.0"
  }
}
